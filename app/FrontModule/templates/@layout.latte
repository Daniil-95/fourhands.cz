<!DOCTYPE html>
<html lang="{$locale}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#8F1125">
    <title>{ifset title}{include title|stripHtml} | {/ifset}Fourhands</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap-grid.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{$basePath}/css/style.css">
    <link rel="icon" href="{$basePath}/images/icons.png" type="image/x-icon">
</head>
<body>
<header class="site-header" data-header>
    <div class="container-fluid site-header__inner">
        <a class="brand" n:href=":Front:Homepage:default locale => $locale" aria-label="Fourhands domů">
            <span class="brand__name">FOURHANDS</span>
            <span class="brand__sub">KLAVÍRNÍ DUO</span>
        </a>
        <button class="menu-toggle" type="button" aria-label="Otevřít menu" aria-expanded="false" data-menu-toggle>
            <span></span><span></span>
        </button>
        <nav class="site-nav" data-menu>
            <a href="{link :Front:Homepage:default, locale => $locale}#uvod">Úvod</a>
            <a href="{link :Front:Homepage:default, locale => $locale}#o-duu">O duu</a>
            <a n:href=":Front:Clenky:default locale => $locale">Členky</a>
            <a href="{link :Front:Homepage:default, locale => $locale}#programy">Programy</a>
            <a n:href=":Front:Galerie:default locale => $locale">Galerie</a>
            <a n:href=":Front:Videa:default locale => $locale">Videa</a>
            <a href="{link :Front:Homepage:default, locale => $locale}#reference">Reference</a>
            <a href="{link :Front:Homepage:default, locale => $locale}#kontakt">Kontakt</a>
            <a class="button button--small" href="{link :Front:Homepage:default, locale => $locale}#kontakt">Poptávka</a>
            <a class="lang-switch" n:href="this locale => $switchLocale">{if $locale == 'cs'}EN{else}CS{/if}</a>
        </nav>
    </div>
</header>

<main>{include content}</main>

<footer class="site-footer">
    <div class="container">
        <div class="row gy-5">
            <div class="col-lg-4">
                <a class="brand brand--footer" n:href=":Front:Homepage:default locale => $locale">
                    <span class="brand__name">FOURHANDS</span>
                    <span class="brand__sub">KLAVÍRNÍ DUO</span>
                </a>

                <p>Klavírní duo pro svatby, koncerty a události, které si zaslouží výjimečnou hudební atmosféru.</p>

                <div class="socials">
                    <a href="#" aria-label="Facebook">f</a>
                    <a href="#" aria-label="Instagram">ig</a>
                    <a href="#" aria-label="YouTube">yt</a>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <h3>Navigace</h3>
                <a href="{link :Front:Homepage:default, locale => $locale}#o-duu">O duu</a>
                <a n:href=":Front:Clenky:default locale => $locale">Členky</a>
                <a n:href=":Front:Galerie:default locale => $locale">Galerie</a>
                <a n:href=":Front:Videa:default locale => $locale">Videa</a>
            </div>
            <div class="col-6 col-lg-3">
                <h3>Programy</h3>
                <a href="{link :Front:Homepage:default, locale => $locale}#programy">Svatby</a>
                <a href="{link :Front:Homepage:default, locale => $locale}#programy">Firemní akce</a>
                <a href="{link :Front:Homepage:default, locale => $locale}#programy">Koncerty</a>
                <a href="{link :Front:Homepage:default, locale => $locale}#programy">Soukromé akce</a>
            </div>
            <div class="col-lg-3"><h3>Kontakt</h3><a href="tel:+420777123456">+420 777 123 456</a><a
                        href="mailto:info@fourhands.cz">info@fourhands.cz</a><span>Praha, Česká republika</span></div>
        </div>
        <div class="site-footer__bottom">
            <span>© Fourhands</span>
            <div><a href="#">GDPR</a><a href="#">Cookies</a></div>
        </div>
    </div>
</footer>
<script src="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.js"></script>
<script src="{$basePath}/js/site.js"></script>
</body>
</html>
