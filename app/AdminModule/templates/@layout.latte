<!DOCTYPE html>
<html lang="cs">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{ifset title}{include title|stripHtml} | {/ifset}Fourhands Administrace</title>
        <link rel="stylesheet" href="{$basePath}/css/admin.css">
    </head>
    <body>
        <a href="#main-content" class="skip-link">Přeskočit na obsah</a>

        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Otevřít menu" aria-expanded="false" type="button">
            &#9776;
        </button>

        <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

        <div class="admin-shell">
            <aside class="sidebar" id="sidebar" role="navigation" aria-label="Hlavní navigace">
                <div class="sidebar-header">
                    <h1>Fourhands</h1>
                    <span class="sidebar-subtitle">Administrace</span>
                </div>
                <nav>
                    <span class="nav-section">Obsah</span>

                    <a n:href=":Admin:Dashboard:default" class="{if $presenter->getName() === 'Admin:Dashboard'}active{/if}">
                        <span class="nav-icon" aria-hidden="true">&#9632;</span> Přehled
                    </a>

                    <a n:href=":Admin:Content:default" class="{if $presenter->getName() === 'Admin:Content'}active{/if}">
                        <span class="nav-icon" aria-hidden="true">&#9632;</span> Bloky obsahu
                    </a>

                    <a n:href=":Admin:Event:default" class="{if $presenter->getName() === 'Admin:Event'}active{/if}">
                        <span class="nav-icon" aria-hidden="true">&#9632;</span> Události
                    </a>

                <a n:href=":Admin:Testimonial:default" class="{if $presenter->getName() === 'Admin:Testimonial'}active{/if}">
                    <span class="nav-icon" aria-hidden="true">&#9632;</span> Reference
                </a>

                <a n:href=":Admin:Program:default" class="{if $presenter->getName() === 'Admin:Program'}active{/if}">
                    <span class="nav-icon" aria-hidden="true">&#9632;</span> Programy
                </a>

                <span class="nav-section">Média</span>

                    <a n:href=":Admin:Media:default" class="{if $presenter->getName() === 'Admin:Media'}active{/if}">
                        <span class="nav-icon" aria-hidden="true">&#9632;</span> Média
                    </a>

                    <span class="nav-section">Nastavení</span>

                    <a n:href=":Admin:Navigation:default" class="{if $presenter->getName() === 'Admin:Navigation'}active{/if}">
                        <span class="nav-icon" aria-hidden="true">&#9632;</span> Menu
                    </a>

                    <a n:href=":Admin:Setting:default" class="{if $presenter->getName() === 'Admin:Setting'}active{/if}">
                        <span class="nav-icon" aria-hidden="true">&#9632;</span> Nastavení webu
                    </a>

                    <span class="nav-section">Nástroje</span>

                    <a n:href=":Front:Homepage:default" target="_blank">
                        <span class="nav-icon" aria-hidden="true">&#9632;</span> Otevřít web
                    </a>

                    <a n:href=":Admin:Sign:out">
                        <span class="nav-icon" aria-hidden="true">&#9632;</span> Odhlásit se
                    </a>
                </nav>
            </aside>

            <main class="main" id="main-content">
                <div class="flash-container">
                    <div n:foreach="$flashes as $flash" class="flash {$flash->type}" role="alert">
                        {$flash->message}
                    </div>
                </div>

                {include content}
            </main>
        </div>

        <script>
            (function() {
                'use strict';

                var toggle = document.getElementById('sidebarToggle');
                var sidebar = document.getElementById('sidebar');
                var backdrop = document.getElementById('sidebarBackdrop');

                if (!toggle || !sidebar) return;

                function openMenu() {
                    sidebar.classList.add('open');
                    backdrop.classList.add('visible');
                    toggle.setAttribute('aria-expanded', 'true');
                    toggle.setAttribute('aria-label', 'Zavřít menu');
                    toggle.innerHTML = '&#10005;';
                    document.body.classList.add('sidebar-open');
                    if (toggle.focus) toggle.focus();
                }

                function closeMenu() {
                    sidebar.classList.remove('open');
                    backdrop.classList.remove('visible');
                    toggle.setAttribute('aria-expanded', 'false');
                    toggle.setAttribute('aria-label', 'Otevřít menu');
                    toggle.innerHTML = '&#9776;';
                    document.body.classList.remove('sidebar-open');
                }

                toggle.addEventListener('click', function(e) {
                    e.stopPropagation();
                    if (sidebar.classList.contains('open')) {
                        closeMenu();
                    } else {
                        openMenu();
                    }
                });

                backdrop.addEventListener('click', closeMenu);

                document.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape' && sidebar.classList.contains('open')) {
                        closeMenu();
                        if (toggle.focus) toggle.focus();
                    }
                });

                // Close sidebar on link click (mobile)
                sidebar.querySelectorAll('a').forEach(function(link) {
                    link.addEventListener('click', function() {
                        if (window.innerWidth <= 920) {
                            closeMenu();
                        }
                    });
                });
            })();
        </script>

        {ifset #scripts}
            {include #scripts}
        {/ifset}
    </body>
</html>
