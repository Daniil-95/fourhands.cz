<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{ifset title}{include title|stripHtml} | {/ifset}Fourhands Admin</title>
    <link rel="stylesheet" href="{$basePath}/css/admin.css">
</head>
<body>
    <div class="admin-shell">
        <aside class="sidebar">
            <h1>Fourhands</h1>
            <nav>
                <a n:href=":Admin:Dashboard:default">Dashboard</a>
                <a n:href=":Admin:Content:default">Content blocks</a>
                <a n:href=":Admin:Event:default">Events</a>
                <a n:href=":Admin:Media:default">Media</a>
                <a n:href=":Front:Homepage:default" target="_blank" rel="noopener">Open site</a>
                <a n:href=":Admin:Sign:out">Sign out</a>
            </nav>
        </aside>
        <main class="main">
            <div n:foreach="$flashes as $flash" class="flash {$flash->type}">{$flash->message}</div>
            {include content}
        </main>
    </div>
</body>
</html>
