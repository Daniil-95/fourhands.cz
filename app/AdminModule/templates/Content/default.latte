{block content}
    <div class="page-header">
        <h2>Bloky obsahu</h2>
        <a class="btn" n:href="edit">Přidat blok</a>
    </div>
    <div class="table-container">
    <table>
        <thead>
        <tr>
            <th>ID</th>
            <th>Jazyk</th>
            <th>Klíč</th>
            <th>Název</th>
            <th>Skupina</th>
            <th>Pořadí</th>
            <th>Stav</th>
            <th>Akce</th>
        </tr>
        </thead>
        <tbody>
        <tr n:foreach="$items as $item">
            <td data-label="ID">{$item->id}</td>
            <td data-label="Jazyk">{$item->lang}</td>
            <td data-label="Klíč"><code>{$item->code}</code></td>
            <td data-label="Název">{$item->title ? $item->title : $item->code}</td>
            <td data-label="Skupina"><span class="badge badge-group badge-group-{$item->category}">{$item->category}</span></td>
            <td data-label="Pořadí">{$item->sort_order}</td>
            <td data-label="Stav">{if $item->active}<span class="badge badge-active">Aktivní</span>{else}<span class="badge badge-inactive">Neaktivní</span>{/if}</td>
            <td data-label="Akce" class="actions-cell">
                <a n:href="edit id => $item->id">Upravit</a>
                <a n:href="delete id => $item->id, _token => $csrfToken" class="btn-delete" onclick="return confirm('Smazat tento blok?')">Smazat</a>
            </td>
        </tr>
        </tbody>
    </table>
    </div>
{/block}
